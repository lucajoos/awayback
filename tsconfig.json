{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": [],

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": false
  },

  "include": ["src/**/*.ts", "test/**/*.test.ts"],
  "exclude": ["node_modules", "dist", "bench/**/*.ts"]
}
