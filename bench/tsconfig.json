{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "..",
    "noEmit": false,
    "allowJs": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.bench.ts"],
  "exclude": ["node_modules", "dist"]
}
